      { id: 110, word1: "Memprotes", word2: "Memrotes", answer: "Memprotes", explanation: "Kata dasar 'protes' (kluster pr), sehingga huruf P tidak luluh." },
      { id: 111, word1: "Mengonsumsi", word2: "Mengkonsumsi", answer: "Mengonsumsi", explanation: "Kata dasar 'konsumsi' (K). Menurut aturan K-P-T-S, huruf K luluh menjadi 'ng'." },
      { id: 112, word1: "Mengomunikasikan", word2: "Mengkomunikasikan", answer: "Mengomunikasikan", explanation: "Kata dasar 'komunikasi' (K). Luluh menjadi 'ng'." },
      { id: 113, word1: "Mengoordinasikan", word2: "Mengkoordinasikan", answer: "Mengoordinasikan", explanation: "Kata dasar 'koordinasi' (K). Luluh menjadi 'ng'." },
      { id: 114, word1: "Mengategorikan", word2: "Mengkategorikan", answer: "Mengategorikan", explanation: "Kata dasar 'kategori' (K). Luluh menjadi 'ng'." },
      { id: 115, word1: "Mengkristal", word2: "Mengristal", answer: "Mengkristal", explanation: "Pengecualian: Kata dasar 'kristal' memiliki konsonan ganda 'kr', sehingga K tidak luluh." },
      { id: 116, word1: "Mengklasifikasi", word2: "Menglasifikasi", answer: "Mengklasifikasi", explanation: "Sama seperti kristal, kluster 'kl' membuat K tidak luluh." },
      { id: 117, word1: "Mengkritik", word2: "Mengritik", answer: "Mengkritik", explanation: "Kata dasar 'kritik'. Kluster 'kr' membuat K tidak luluh." },
      { id: 118, word1: "Menyosialisasikan", word2: "Mensosialisasikan", answer: "Menyosialisasikan", explanation: "Kata dasar 'sosialisasi' (S). Menurut aturan K-P-T-S, huruf S luluh menjadi 'ny'." },
      { id: 119, word1: "Menyukseskan", word2: "Mensukseskan", answer: "Menyukseskan", explanation: "Kata dasar 'sukses' (S). Luluh menjadi 'ny'." },
      { id: 120, word1: "Menyintesis", word2: "Mensintesis", answer: "Menyintesis", explanation: "Kata dasar 'sintesis' (S). Luluh menjadi 'ny'." },
      { id: 121, word1: "Mensyukuri", word2: "Menyukuri", answer: "Mensyukuri", explanation: "Pengecualian! Kata dasar berawalan gabungan konsonan 'sy' (syukur) TIDAK luluh." },
      { id: 122, word1: "Mensyaratkan", word2: "Menyaratkan", answer: "Mensyaratkan", explanation: "Sama seperti syukur, awalan 'sy' pada 'syarat' tidak luluh." },
      { id: 123, word1: "Menerjemahkan", word2: "Menterjemahkan", answer: "Menerjemahkan", explanation: "Kata dasar 'terjemah' (T). Menurut aturan K-P-T-S, huruf T luluh menjadi 'n'." },
      { id: 124, word1: "Menertawakan", word2: "Mentertawakan", answer: "Menertawakan", explanation: "Kata dasar 'tertawa' (T). Luluh menjadi 'n'." },
      { id: 125, word1: "Menerapkan", word2: "Menterapkan", answer: "Menerapkan", explanation: "Kata dasar 'terap' (T). Luluh menjadi 'n'." },
      { id: 126, word1: "Memfasilitasi", word2: "Mefasilitasi", answer: "Memfasilitasi", explanation: "Huruf F dan V pada kata serapan bahasa asing TIDAK luluh saat diberi awalan me-." },
      { id: 127, word1: "Memvonis", word2: "Mevonis", answer: "Memvonis", explanation: "Sama seperti F, awalan V pada 'vonis' juga tidak luluh." },
      { id: 128, word1: "Memfitnah", word2: "Mefitnah", answer: "Memfitnah", explanation: "Kata 'fitnah' mempertahankan huruf F-nya, menjadi memfitnah." },
      { id: 129, word1: "Mempunyai", word2: "Memunyai", answer: "Mempunyai", explanation: "Pengecualian sejarah! Walaupun berawalan P (punya), kata ini ditetapkan baku dengan tetap memakai P." },
      { id: 130, word1: "Mempelajari", word2: "Memelajari", answer: "Mempelajari", explanation: "Berasal dari ajar + pe- = pelajar. Kata dasar 'pelajar' P-nya tidak luluh karena 'pe' adalah imbuhan, bukan huruf asli." },
      { id: 131, word1: "Mempertahankan", word2: "Memertahankan", answer: "Mempertahankan", explanation: "Berasal dari tahan + per-. P tidak luluh karena 'per-' di sini adalah imbuhan sisipan." },
      { id: 132, word1: "Mengilat", word2: "Mengkilat", answer: "Mengilat", explanation: "Kata dasar 'kilat' (K). Luluh menjadi 'ng'." },
      { id: 133, word1: "Mengait", word2: "Mengkait", answer: "Mengait", explanation: "Kata dasar 'kait' (K). Luluh menjadi 'ng'." },
      { id: 134, word1: "Mencuci", word2: "Menyuci", answer: "Mencuci", explanation: "Hanya K, P, T, S yang luluh. Huruf C tidak luluh. Tetap mencuci, bukan menyuci." },
      { id: 135, word1: "Mencintai", word2: "Menyintai", answer: "Mencintai", explanation: "Huruf C pada 'cinta' tidak luluh. Menjadi mencintai." },
      { id: 136, word1: "Mencolok", word2: "Menyolok", answer: "Mencolok", explanation: "Kata dasarnya 'colok'. C tidak luluh, sehingga tetap mencolok." },
      { id: 137, word1: "Menyontek", word2: "Mencontek", answer: "Menyontek", explanation: "Kata dasarnya adalah 'sontek' (S). Maka luluh menjadi 'ny' (menyontek)." },
      { id: 138, word1: "Mengebom", word2: "Membom", answer: "Mengebom", explanation: "Kata dasar yang hanya punya 1 suku kata (bom, cat, tik) akan mendapat awalan 'menge-'." },
      { id: 139, word1: "Mengecat", word2: "Mencat", answer: "Mengecat", explanation: "Sama seperti bom, kata 1 suku kata (cat) ditambah awalan 'menge-'." },
      { id: 140, word1: "Mengetik", word2: "Mentik", answer: "Mengetik", explanation: "Berasal dari kata dasar 1 suku kata 'tik'." },
      { id: 141, word1: "Mengeklik", word2: "Mengklik", answer: "Mengeklik", explanation: "Berasal dari kata dasar 1 suku kata 'klik'." },
      { id: 142, word1: "Mengetes", word2: "Mentes", answer: "Mengetes", explanation: "Berasal dari kata dasar 1 suku kata 'tes'." },
      { id: 143, word1: "Perusak", word2: "Pengrusak", answer: "Perusak", explanation: "Kata dasar berawalan R (rusak) jika diberi awalan pe- menjadi pe+rusak (perusak)." },
      { id: 144, word1: "Perajin", word2: "Pengrajin", answer: "Perajin", explanation: "Berasal dari pe+rajin. Tidak ada bunyi 'ng', tetap perajin." },
      { id: 145, word1: "Pegolf", word2: "Penggolf", answer: "Pegolf", explanation: "Berawalan konsonan g, cukup pakai pe- (pegolf)." },
      { id: 146, word1: "Petinju", word2: "Peninju", answer: "Petinju", explanation: "Untuk profesi atau atlet olahraga (tinju), imbuhan yang tepat adalah pe- (petinju)." },
      { id: 147, word1: "Permukiman", word2: "Pemukiman", answer: "Permukiman", explanation: "Imbuhan per-an (permukiman) menyatakan tempat/lokasi. Pem-an menyatakan proses." },
      { id: 148, word1: "Perdesaan", word2: "Pedesaan", answer: "Perdesaan", explanation: "Berasal dari desa + konfiks per-an. Menjadi perdesaan." },
      { id: 149, word1: "Perkotaan", word2: "Pekotaan", answer: "Perkotaan", explanation: "Sama seperti perdesaan, berasal dari kota + konfiks per-an." },
      { id: 150, word1: "Pertanggungjawaban", word2: "Pertanggung jawaban", answer: "Pertanggungjawaban", explanation: "Aturan konfiks: Jika dua kata dasar mendapat awalan dan akhiran sekaligus, wajib ditulis serangkai." },
      { id: 151, word1: "Menandatangani", word2: "Menanda tangani", answer: "Menandatangani", explanation: "Mendapat konfiks me-i sekaligus, jadi 'tanda tangan' ditulis serangkai tanpa spasi." },
      { id: 152, word1: "Menggarisbawahi", word2: "Menggaris bawahi", answer: "Menggarisbawahi", explanation: "Mendapat konfiks me-i sekaligus, jadi 'garis bawah' ditulis serangkai." },
      { id: 153, word1: "Menghancurleburkan", word2: "Menghancur leburkan", answer: "Menghancurleburkan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 154, word1: "Menyebarluaskan", word2: "Menyebar luaskan", answer: "Menyebarluaskan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 155, word1: "Memutarbalikkan", word2: "Memutar balikkan", answer: "Memutarbalikkan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 156, word1: "Memberitahukan", word2: "Memberi tahukan", answer: "Memberitahukan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 157, word1: "Menganaktirikan", word2: "Menganak tirikan", answer: "Menganaktirikan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 158, word1: "Melipatgandakan", word2: "Melipat gandakan", answer: "Melipatgandakan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 159, word1: "Mengambinghitamkan", word2: "Mengambing hitamkan", answer: "Mengambinghitamkan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 160, word1: "Mengalihbahasakan", word2: "Mengalih bahasakan", answer: "Mengalihbahasakan", explanation: "Mendapat konfiks me-kan sekaligus, wajib ditulis serangkai." },
      { id: 161, word1: "Dipertanggungjawabkan", word2: "Dipertanggung jawabkan", answer: "Dipertanggungjawabkan", explanation: "Mendapat konfiks di-kan (bentuk pasif), dua kata dasar wajib digabung." },
      { id: 162, word1: "Disebarluaskan", word2: "Disebar luaskan", answer: "Disebarluaskan", explanation: "Mendapat konfiks di-kan, wajib digabung." },
      { id: 163, word1: "Dianaktirikan", word2: "Di anak tirikan", answer: "Dianaktirikan", explanation: "Mendapat konfiks di-kan, wajib digabung." },
      { id: 164, word1: "Diberitahukan", word2: "Diberi tahukan", answer: "Diberitahukan", explanation: "Mendapat konfiks di-kan, wajib digabung." },
      { id: 165, word1: "Dialihbahasakan", word2: "Dialih bahasakan", answer: "Dialihbahasakan", explanation: "Mendapat konfiks di-kan, wajib digabung." },
      { id: 166, word1: "Ketidakhadiran", word2: "Ketidak hadiran", answer: "Ketidakhadiran", explanation: "Mendapat konfiks ke-an sekaligus, wajib ditulis serangkai." },
      { id: 167, word1: "Ketidakadilan", word2: "Ketidak adilan", answer: "Ketidakadilan", explanation: "Mendapat konfiks ke-an sekaligus, wajib ditulis serangkai." },
      { id: 168, word1: "Kesiapsiagaan", word2: "Kesiap siagaan", answer: "Kesiapsiagaan", explanation: "Mendapat konfiks ke-an sekaligus, wajib ditulis serangkai." },
      { id: 169, word1: "Ketertinggalan", word2: "Ke tertinggalan", answer: "Ketertinggalan", explanation: "Mendapat konfiks ke-an, awalan ke- digabung penuh." },
      { id: 170, word1: "Keterlaluan", word2: "Ke terlaluan", answer: "Keterlaluan", explanation: "Mendapat konfiks ke-an, digabung penuh." },
      { id: 171, word1: "Berterima kasih", word2: "Berterimakasih", answer: "Berterima kasih", explanation: "Aturan awalan: Jika hanya mendapat awalan ber- (tanpa akhiran), kata kedua tetap dipisah." },
      { id: 172, word1: "Bertanggung jawab", word2: "Bertanggungjawab", answer: "Bertanggung jawab", explanation: "Hanya mendapat awalan ber-, sehingga kata kedua 'jawab' wajib dipisah." },
      { id: 173, word1: "Bekerja sama", word2: "Bekerjasama", answer: "Bekerja sama", explanation: "Hanya mendapat awalan be-, kata kedua 'sama' tetap dipisah." },
      { id: 174, word1: "Berlipat ganda", word2: "Berlipatganda", answer: "Berlipat ganda", explanation: "Hanya mendapat awalan ber-, dipisah." },
      { id: 175, word1: "Tepuk tangan", word2: "Tepuktangan", answer: "Tepuk tangan", explanation: "Dua kata dasar terpisah, tidak digabung jika tidak ada konfiks/imbuhan gabung." },
      { id: 176, word1: "Bertepuk tangan", word2: "Bertepuktangan", answer: "Bertepuk tangan", explanation: "Hanya mendapat awalan, tetap dipisah." },
      { id: 177, word1: "Beraneka ragam", word2: "Beranekaragam", answer: "Beraneka ragam", explanation: "Hanya mendapat awalan, tetap dipisah." },
      { id: 178, word1: "Ikut serta", word2: "Ikutserta", answer: "Ikut serta", explanation: "Tanpa imbuhan konfiks, frasa ini tetap ditulis terpisah." },
      { id: 179, word1: "Bekerja", word2: "Berkerja", answer: "Bekerja", explanation: "Aturan luluh r: Awalan ber- bertemu kata dengan suku pertama 'er' (kerja), maka r-nya luluh." },
      { id: 180, word1: "Beternak", word2: "Berternak", answer: "Beternak", explanation: "Sama seperti bekerja, ber + ternak luluh menjadi beternak." },
      { id: 181, word1: "Beragam", word2: "Berragam", answer: "Beragam", explanation: "Awalan ber- bertemu kata awalan R (ragam), cukup ditulis satu R saja (lebur)." },
      { id: 182, word1: "Berevolusi", word2: "Berrevolusi", answer: "Berevolusi", explanation: "Kata dasarnya evolusi (huruf E). Jadi ber- + evolusi = berevolusi." },
      { id: 183, word1: "Beresolusi", word2: "Berresolusi", answer: "Beresolusi", explanation: "Kata dasar resolusi (huruf R). Huruf R-nya melebur jadi satu (beresolusi)." },
      { id: 184, word1: "Terekam", word2: "Terrekam", answer: "Terekam", explanation: "Sama seperti ber-, awalan ter- bertemu huruf R (rekam), R-nya melebur jadi satu." },
      { id: 185, word1: "Terasa", word2: "Terrasa", answer: "Terasa", explanation: "Awalan ter- bertemu huruf R (rasa), R-nya melebur jadi satu." },
      { id: 186, word1: "Tepercik", word2: "Terpercik", answer: "Tepercik", explanation: "Awalan ter- bertemu kata dengan suku kata pertama 'per' (percik), r-nya luluh jadi te-." },
      { id: 187, word1: "Teperdaya", word2: "Terperdaya", answer: "Teperdaya", explanation: "Awalan ter- bertemu kata 'perdaya', r-nya luluh jadi te-." },
      { id: 188, word1: "Telanjur", word2: "Terlanjur", answer: "Telanjur", explanation: "Bentuk baku yang ditetapkan KBBI. Mengikuti pola luluh khusus menjadi telanjur." },
      { id: 189, word1: "Menertibkan", word2: "Mentertibkan", answer: "Menertibkan", explanation: "Kata dasar 'tertib' (T). T luluh menjadi 'n' (menertibkan)." },
      { id: 190, word1: "Minimalisasi", word2: "Minimalisir", answer: "Minimalisasi", explanation: "Akhiran serapan (Belanda -ir vs Inggris -asi). Yang dibakukan di Indonesia adalah '-asi'." },
      { id: 191, word1: "Optimalisasi", word2: "Optimalisir", answer: "Optimalisasi", explanation: "Menggunakan akhiran '-asi', menjadi optimalisasi." },
      { id: 192, word1: "Netralisasi", word2: "Netralisir", answer: "Netralisasi", explanation: "Menggunakan akhiran '-asi', menjadi netralisasi." },
      { id: 193, word1: "Lokalisasi", word2: "Lokalisir", answer: "Lokalisasi", explanation: "Menggunakan akhiran '-asi', menjadi lokalisasi." },
      { id: 194, word1: "Dimengerti", word2: "Di mengerti", answer: "Dimengerti", explanation: "'di-' di sini adalah imbuhan pembentuk pasif (lawan mengerti), sehingga wajib digabung." },
      { id: 195, word1: "Dimakan", word2: "Di makan", answer: "Dimakan", explanation: "Sama seperti dimengerti, 'di-' adalah imbuhan pembentuk kata kerja pasif." },
      { id: 196, word1: "Di mana", word2: "Dimana", answer: "Di mana", explanation: "Aturan preposisi: 'di' sebagai kata penunjuk tempat adalah kata depan, wajib dipisah." },
      { id: 197, word1: "Di atas", word2: "Diatas", answer: "Di atas", explanation: "Penunjuk tempat (atas). Kata depan 'di' wajib dipisah." },
      { id: 198, word1: "Di antaranya", word2: "Diantaranya", answer: "Di antaranya", explanation: "Kata depan 'di' menunjukkan letak/posisi, wajib dipisah." },
      { id: 199, word1: "Ke mana", word2: "Kemana", answer: "Ke mana", explanation: "Sama seperti 'di mana', 'ke' di sini adalah preposisi penunjuk arah, wajib dipisah." },
      { id: 200, word1: "Kemari", word2: "Ke mari", answer: "Kemari", explanation: "Pengecualian khusus! Meski 'ke' dipisah untuk arah, frasa 'kemari' wajib digabung menurut KBBI." },
      { id: 201, word1: "Abjad", word2: "Abjat", answer: "Abjad", explanation: "Penulisan baku menggunakan huruf 'd' di akhir kata." },
      { id: 202, word1: "Afdal", word2: "Afdol", answer: "Afdal", explanation: "Diserap dari bahasa Arab, penulisan bakunya menggunakan huruf 'a'." },
      { id: 203, word1: "Akhlak", word2: "Ahlak", answer: "Akhlak", explanation: "Kata baku dari bahasa Arab ini harus menggunakan gabungan huruf 'kh'." },
      { id: 204, word1: "Ambeien", word2: "Ambeyen", answer: "Ambeien", explanation: "Kata bakunya ditulis dengan huruf 'i' dan 'e', tanpa huruf 'y'." },
      { id: 205, word1: "Al-Qur'an", word2: "Alquran", answer: "Al-Qur'an", explanation: "Menurut standar KBBI, penulisan kitab suci ini menggunakan tanda hubung dan apostrof." },
      { id: 206, word1: "Atmosfer", word2: "Atmosfir", answer: "Atmosfer", explanation: "Diserap dari 'atmosphere', akhiran yang benar adalah '-fer', bukan '-fir'." },
      { id: 207, word1: "Azan", word2: "Adzan", answer: "Azan", explanation: "Penulisan yang baku menurut ejaan bahasa Indonesia menggunakan huruf 'z' saja." },
      { id: 208, word1: "Bolpoin", word2: "Bolpen", answer: "Bolpoin", explanation: "Diserap dari bahasa Inggris 'ballpoint', disesuaikan menjadi bolpoin." },
      { id: 209, word1: "Bujet", word2: "Budget", answer: "Bujet", explanation: "Kata serapan dari bahasa Inggris 'budget' sudah disesuaikan ejaannya menjadi bujet." },
      { id: 210, word1: "Cabai", word2: "Cabe", answer: "Cabai", explanation: "Kata bakunya menggunakan akhiran '-ai' (cabai), bukan '-e' (cabe)." },
      { id: 211, word1: "Detergen", word2: "Deterjen", answer: "Detergen", explanation: "Huruf 'g' dipertahankan dari kata aslinya (detergent)." },
      { id: 212, word1: "Ekspor", word2: "Eksport", answer: "Ekspor", explanation: "Diserap tanpa huruf 't' di akhir kata." },
      { id: 213, word1: "Embus", word2: "Hembus", answer: "Embus", explanation: "Sama seperti utang dan isap, kata ini baku tanpa awalan huruf 'h'." },
      { id: 214, word1: "Esai", word2: "Esei", answer: "Esai", explanation: "Diserap dari kata 'essay', penulisan yang baku berakhiran '-ai'." },
      { id: 215, word1: "Gubuk", word2: "Gubug", answer: "Gubuk", explanation: "Penulisan yang benar menurut KBBI berakhiran huruf 'k'." },
      { id: 216, word1: "Hadis", word2: "Hadist", answer: "Hadis", explanation: "Tidak perlu ada huruf 't' di akhir kata (hadis)." },
      { id: 217, word1: "Ideologi", word2: "Idiologi", answer: "Ideologi", explanation: "Berasal dari kata 'idea', jadi menggunakan huruf 'e' bukan 'i' di tengahnya." },
      { id: 218, word1: "Ikhlas", word2: "Ihlas", answer: "Ikhlas", explanation: "Penulisan yang baku harus menyertakan gabungan huruf 'kh'." },
      { id: 219, word1: "Kanguru", word2: "Kangguru", answer: "Kanguru", explanation: "Sering salah ditulis kangguru (dengan ng-g), yang baku hanya memakai 'ng' (kanguru)." },
      { id: 220, word1: "Kompleks", word2: "Komplek", answer: "Kompleks", explanation: "Diserap dari 'complex', sehingga harus berakhiran '-ks'." },
      { id: 221, word1: "Maaf", word2: "Ma'af", answer: "Maaf", explanation: "Dalam ejaan yang disempurnakan, tanda apostrof (') tidak digunakan untuk kata ini." },
      { id: 222, word1: "Magrib", word2: "Maghrib", answer: "Magrib", explanation: "Sama seperti karisma, gabungan huruf 'gh' cukup ditulis 'g' (magrib)." },
      { id: 223, word1: "Massal", word2: "Masal", answer: "Massal", explanation: "Diserap dari kata 'mass' (massa), sehingga huruf 's'-nya ganda (massal)." },
      { id: 224, word1: "Mikraj", word2: "Mi'raj", answer: "Mikraj", explanation: "Tanda apostrof (ain) pada kata serapan Arab sering diganti dengan huruf 'k' dalam penulisan kata turunan atau serapan tertentu, namun Mikraj ditulis gabung." },
      { id: 225, word1: "Museum", word2: "Musium", answer: "Museum", explanation: "Dipertahankan sesuai bahasa aslinya, menggunakan huruf 'e'." },
      { id: 226, word1: "Objek", word2: "Obyek", answer: "Objek", explanation: "Ejaan bahasa Indonesia menggunakan huruf 'j' untuk kata serapan 'object'." },
      { id: 227, word1: "Paspor", word2: "Pasport", answer: "Paspor", explanation: "Sama seperti ekspor, diserap tanpa huruf 't'." },
      { id: 228, word1: "Peduli", word2: "Perduli", answer: "Peduli", explanation: "Tidak ada huruf 'r' di dalam kata ini. Yang baku adalah peduli." },
      { id: 229, word1: "Penasihat", word2: "Penasehat", answer: "Penasihat", explanation: "Kata dasarnya nasihat, jika ditambah awalan pe- menjadi penasihat." },
      { id: 230, word1: "Peranti", word2: "Piranti", answer: "Peranti", explanation: "Bentuk bakunya menggunakan awalan pe- (peranti), bukan pi-." },
      { id: 231, word1: "Rezeki", word2: "Rejeki", answer: "Rezeki", explanation: "Berasal dari bahasa Arab yang huruf aslinya diserap menjadi huruf 'z'." },
      { id: 232, word1: "Relief", word2: "Relif", answer: "Relief", explanation: "Dipertahankan ejaan aslinya yang menggunakan gabungan vokal 'ie'." },
      { id: 233, word1: "Responden", word2: "Respondens", answer: "Responden", explanation: "Diserap menjadi responden (tanpa huruf 's' di akhir)." },
      { id: 234, word1: "Satai", word2: "Sate", answer: "Satai", explanation: "Sama seperti cabai dan baterai, penulisan bakunya berakhiran '-ai'." },
      { id: 235, word1: "Saus", word2: "Saos", answer: "Saus", explanation: "Penulisan baku yang terdaftar di KBBI adalah saus (menggunakan 'u')." },

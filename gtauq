    // --- Komponen Utama ---
    function App() {
      const [flashcards, setFlashcards] = useState([...initialFlashcards]);
      const [currentIndex, setCurrentIndex] = useState(0);
      const [isFlipped, setIsFlipped] = useState(false);
      const [direction, setDirection] = useState(''); 

      const handleNext = useCallback(() => {
        setIsFlipped(false);
        setDirection('right');
        setTimeout(() => {
          setCurrentIndex((prev) => (prev + 1) % flashcards.length);
          setDirection('');
        }, 150);
      }, [flashcards.length]);

      const handlePrev = useCallback(() => {
        setIsFlipped(false);
        setDirection('left');
        setTimeout(() => {
          setCurrentIndex((prev) => (prev - 1 + flashcards.length) % flashcards.length);
          setDirection('');
        }, 150);
      }, [flashcards.length]);

      const handleShuffle = () => {
        setIsFlipped(false);
        setDirection('down');
        setTimeout(() => {
          const shuffled = [...flashcards].sort(() => Math.random() - 0.5);
          setFlashcards(shuffled);
          setCurrentIndex(0);
          setDirection('');
        }, 150);
      };

      const handleReset = () => {
        setIsFlipped(false);
        setFlashcards([...initialFlashcards]);
        setCurrentIndex(0);
      };

      useEffect(() => {
        const handleKeyDown = (e) => {
          if (e.key === 'ArrowRight') handleNext();
          if (e.key === 'ArrowLeft') handlePrev();
          if (e.key === ' ' || e.key === 'ArrowUp' || e.key === 'ArrowDown') {
            e.preventDefault();
            setIsFlipped((prev) => !prev);
          }
        };
        window.addEventListener('keydown', handleKeyDown);
        return () => window.removeEventListener('keydown', handleKeyDown);
      }, [handleNext, handlePrev]);

      const currentCard = flashcards[currentIndex];
      const progress = ((currentIndex + 1) / flashcards.length) * 100;

      return (
        <div className="min-h-screen bg-slate-50 flex flex-col items-center py-10 px-4 font-sans text-slate-800">
          <div className="max-w-2xl w-full text-center mb-8">
            <div className="inline-flex items-center justify-center p-3 bg-indigo-100 rounded-full mb-4 text-indigo-600">
              <BookOpen size={32} />
            </div>
            <h1 className="text-3xl md:text-4xl font-extrabold text-slate-900 mb-2 tracking-tight">
              Flashcard PPU UTBK
            </h1>
            <p className="text-slate-500">
              Latihan tebak kata baku & tidak baku. Klik kartu atau tekan Spasi untuk membalik.
            </p>
          </div>

          <div className="max-w-xl w-full mb-8">
            <div className="flex justify-between text-sm font-medium text-slate-500 mb-2">
              <span>Kartu {currentIndex + 1} dari {flashcards.length}</span>
              <span>{Math.round(progress)}% Selesai</span>
            </div>
            <div className="w-full bg-slate-200 rounded-full h-2.5">
              <div 
                className="bg-indigo-600 h-2.5 rounded-full transition-all duration-500 ease-out" 
                style={{ width: `${progress}%` }}
              ></div>
            </div>
          </div>

          <div className="max-w-xl w-full perspective-1000 mb-10 h-80 relative">
            <div 
              onClick={() => setIsFlipped(!isFlipped)}
              className={`w-full h-full relative cursor-pointer transition-all duration-500 ease-in-out`}
              style={{ 
                perspective: '1000px',
                transform: direction === 'right' ? 'translateX(20px) opacity(0)' : direction === 'left' ? 'translateX(-20px) opacity(0)' : direction === 'down' ? 'translateY(20px) opacity(0)' : 'none',
                opacity: direction ? 0 : 1
              }}
            >
              <div 
                className="w-full h-full absolute top-0 left-0 transition-transform duration-500 ease-in-out"
                style={{ transformStyle: 'preserve-3d', transform: isFlipped ? 'rotateY(180deg)' : 'rotateY(0deg)' }}
              >
                
                <div 
                  className="absolute w-full h-full bg-white rounded-3xl shadow-lg border border-slate-100 flex flex-col items-center justify-center p-8 text-center hover:shadow-xl transition-shadow"
                  style={{ backfaceVisibility: 'hidden' }}
                >
                  <span className="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-6">Manakah yang baku?</span>
                  <div className="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 w-full">
                    <span className="text-3xl md:text-4xl font-bold text-slate-800 break-words">{currentCard.word1}</span>
                    <span className="text-xl font-medium text-slate-400 italic">atau</span>
                    <span className="text-3xl md:text-4xl font-bold text-slate-800 break-words">{currentCard.word2}</span>
                  </div>
                  <div className="absolute bottom-6 text-sm text-slate-400 animate-pulse flex items-center gap-2">
                    <RotateCcw size={16} /> Klik untuk melihat jawaban
                  </div>
                </div>

                <div 
                  className="absolute w-full h-full bg-indigo-600 rounded-3xl shadow-lg flex flex-col items-center justify-center p-8 text-center"
                  style={{ backfaceVisibility: 'hidden', transform: 'rotateY(180deg)' }}
                >
                  <div className="bg-white/20 p-2 rounded-full mb-4">
                    <CheckCircle2 size={32} className="text-white" />
                  </div>
                  <span className="text-xs font-bold uppercase tracking-widest text-indigo-200 mb-2">Jawaban Benar</span>
                  <h2 className="text-4xl md:text-5xl font-extrabold text-white mb-6 tracking-wide">
                    {currentCard.answer}
                  </h2>
                  <div className="w-16 h-1 bg-indigo-400 rounded mb-6"></div>
                  <p className="text-indigo-100 text-lg md:text-xl font-medium max-w-md leading-relaxed overflow-y-auto">
                    {currentCard.explanation}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div className="flex items-center justify-center gap-4 md:gap-6 w-full max-w-xl">
            <button onClick={handlePrev} className="p-4 rounded-full bg-white text-slate-600 shadow-sm border border-slate-200 hover:bg-slate-50 hover:text-indigo-600 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" title="Sebelumnya (Panah Kiri)">
              <ArrowLeft size={24} />
            </button>
            <button onClick={handleShuffle} className="flex items-center gap-2 px-6 py-4 rounded-full bg-white text-slate-600 shadow-sm border border-slate-200 hover:bg-slate-50 hover:text-indigo-600 transition-colors font-semibold focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" title="Acak Urutan">
              <Shuffle size={20} />
              <span className="hidden sm:inline">Acak Kartu</span>
            </button>
            <button onClick={handleNext} className="p-4 rounded-full bg-indigo-600 text-white shadow-md hover:bg-indigo-700 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" title="Selanjutnya (Panah Kanan)">
              <ArrowRight size={24} />
            </button>
          </div>

          <div className="mt-12 text-center text-sm text-slate-400 max-w-md">
            <p>Gunakan tombol <kbd className="px-2 py-1 bg-slate-200 rounded text-slate-600 mx-1">Spasi</kbd> untuk membalik kartu dan <kbd className="px-2 py-1 bg-slate-200 rounded text-slate-600 mx-1">←</kbd> <kbd className="px-2 py-1 bg-slate-200 rounded text-slate-600 mx-1">→</kbd> untuk navigasi cepat.</p>
            <button onClick={handleReset} className="mt-4 text-indigo-500 hover:text-indigo-600 underline underline-offset-4 decoration-indigo-200">
              Reset ke Urutan Awal
            </button>
          </div>
        </div>
      );
    }

    // Render ke layar
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
